# =================================================================
# 球后说 · 环境变量
# =================================================================
# Stage 1 合规决策：LLM 必须用境内备案大模型，禁用 GPT-4o/Claude 在生产环境
# 本地 dev 可继续用 Claude / OpenAI 验证 prompt 行为，prod 必须切换。
# =================================================================
# Production deploy 前必修条目（boot guard 会 fail-fast）：
#   - WX_APPID / WX_SECRET（小程序登录）
#   - WECOM_BOT_WEBHOOK 或 DINGTALK_BOT_WEBHOOK 至少一个（告警通道）
#   - 数美 或 易盾 secretId（safety L2 远程审核，L09 合同到位后）
# =================================================================

# --- LLM Providers (境内备案模型优先) ---
# 豆包（火山引擎 Ark）—— 主用，已通过算法备案
# Doubao Seed 1.6 系列（2025-06 发布的主力生产线，截至 2026-05 仍为最新）
# 实际 model ID 以火山方舟控制台为准：https://www.volcengine.com/docs/82379
DOUBAO_API_KEY=
DOUBAO_MODEL_REPORT=doubao-seed-1-6-250615         # 战报生成（pro 主力，平衡质量 + 价格）
DOUBAO_MODEL_HOST=doubao-seed-1-6-flash-250615     # 老李群聊（flash，短输出 + 低延迟 + 价格 1/3）；L11 群聊接入后启用
DOUBAO_MODEL_PREMIUM=doubao-seed-1-6-thinking-250715  # 决赛日深度战报 ¥9 SKU（thinking，长战术分析）；W5+ SKU 落地后启用
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包 Seedream 图片生成（精彩镜头后期自动化）
HIGHLIGHT_IMAGE_PROVIDER=mock              # mock | doubao；doubao 会调用 /images/generations 并写入 COS
DOUBAO_IMAGE_MODEL=doubao-seedream-4-0-250828
DOUBAO_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_IMAGE_SIZE=2K
DOUBAO_IMAGE_WATERMARK=1                  # 1=保留模型水印；0=关闭（需确认平台/合规要求）
DOUBAO_IMAGE_TIMEOUT_MS=90000

# —— 老李赛后视频（默认 mock，不产生 Seedance/TTS 费用）——
LAOLI_VIDEO_ENABLED=                   # 1/true 才允许手动生成；缺省关
LAOLI_VIDEO_AUTO=                      # 1/true 才由 auto-report 异步触发；缺省关
LAOLI_REEL_STORY=                      # =0 关掉 reel 故事化旁白(LLM 讲戏剧点),关/失败回退确定性模板;缺省开
LAOLI_REEL_ARC=                        # =0 关掉六拍变长争议弧(单场默认),回退四拍判卷/模板;缺省开(A/B 切回四拍用)
LAOLI_REEL_PIP_MODE=                   # shared(默认·通用老李片段循环·每场0段seedance) | lipsync(每段对口型·重点场,贵)
LAOLI_VIDEO_PROVIDER=mock              # mock | doubao
LAOLI_TTS_PROVIDER=mock                # mock | volc(v1 旧) | volc-v3(大模型 seed-tts-2.0,精简版用这个)
DOUBAO_VIDEO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_VIDEO_MODEL=doubao-seedance-2-0-260128
DOUBAO_VIDEO_POLL_INTERVAL_MS=5000
DOUBAO_VIDEO_TIMEOUT_MS=180000
VOLC_TTS_ENDPOINT=https://openspeech.bytedance.com/api/v1/tts
VOLC_TTS_APP_ID=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_SECRET_KEY=
VOLC_TTS_CLUSTER=volcano_tts
VOLC_TTS_RESOURCE_ID=                  # 控制台「服务接口认证信息」中的大模型 TTS Resource-Id
VOLC_TTS_VOICE=zh_male_yunzhou_jupiter_bigtts
VOLC_TTS_MODEL=1.2.1.1
VOLC_TTS_TIMEOUT_MS=60000
FFMPEG_PATH=ffmpeg                     # 生产机可填绝对路径
FFPROBE_PATH=ffprobe                   # 老李 reel 取片段真实时长(排时间轴);apt 装 ffmpeg 自带
LAOLI_VIDEO_RENDER_PROGRESS=           # =1 输出 Remotion bundling/render 进度日志
REMOTION_BROWSER_EXECUTABLE=            # 可选：系统 Chrome/Chromium 绝对路径，避免首次自动下载
# 老李口播为主·对口型(数字人主播)。缺省关；provider 可切：seedance(复用 DOUBAO_API_KEY)| omnihuman(需下方 AK/SK)
LAOLI_AVATAR_ENABLED=                   # 1/true 才走对口型；缺省关→沿用动态背景路径
LAOLI_AVATAR_PROVIDER=mock             # mock | seedance | omnihuman
LAOLI_AVATAR_MODE=compose              # lean(裸 OmniHuman 口播直出,无 Remotion/ffmpeg) | compose(旧版叠卡)
LAOLI_REF_PUBLIC_URL=https://qiuhoushuo.com/persona/laoli-ref.png  # OmniHuman 必需的老李公网图
VOLC_TTS_SAMPLE_RATE=24000             # 大模型 TTS 采样率
OMNIHUMAN_ACCESS_KEY=                   # 火山智能视觉 AK（控制台开通后只进生产机 .env，禁入 git）
OMNIHUMAN_SECRET_KEY=                   # 火山智能视觉 SK
OMNIHUMAN_HOST=visual.volcengineapi.com
OMNIHUMAN_REGION=cn-north-1
OMNIHUMAN_SERVICE=cv
OMNIHUMAN_REQ_KEY=jimeng_realman_avatar_picture_omni_v15
OMNIHUMAN_POLL_INTERVAL_MS=3000
OMNIHUMAN_TIMEOUT_MS=600000

# 球迷形象生成（图生图；6/11 实现，feature.fan_avatar 灰度门默认关）
# ⚠️ 合规硬 gate：AIGC 三件套受理回执 + 律师评估人脸处理方案之前，FEATURE_FLAG_FAN_AVATAR 不得 >0。
# 代码红线：水印恒开（DOUBAO_IMAGE_WATERMARK 对本功能无效）；输入自拍不落盘；prompt 锁非写实插画风。
FAN_AVATAR_PROVIDER=                      # mock | doubao；不配回退 HIGHLIGHT_IMAGE_PROVIDER
DOUBAO_AVATAR_MODEL=                      # 不配回退 DOUBAO_IMAGE_MODEL（seedream 4.0 支持 image 参数图生图）
DOUBAO_AVATAR_SIZE=1K

# --- 功能灰度（FEATURE_FLAG_* → feature.*；0-100 百分比，不配=关）---
FEATURE_FLAG_TACTICS_CARD=                # 战术图解卡（/api/card/tactics）；数据来自 API-Football lineups，无合规依赖，可先开
FEATURE_FLAG_FAN_AVATAR=                  # 球迷形象生成（POST /api/avatar）；🔴 备案回执前必须保持空/0
# ⚠️ 与球星合影（真实球星·肖像权/深度合成红线）——两道独立门：
FEATURE_FLAG_FAN_AVATAR_COSTAR=          # 生成门（/api/avatar mode=costar 放行）；空=关。生产 2026-06-26 已开=100（founder 拍板）。
FEATURE_FLAG_FAN_AVATAR_COSTAR_ENTRY=    # 小程序入口门（/api/avatar/config 下发，控制「与球星合影」入口是否展示）；🔴 微信小程序审核期保持空/0→入口隐藏、干净过审；过审发布后再翻 100。kill/翻开用 deploy/feature-flag.sh

# DeepSeek —— 备 LLM，决赛日双供应商热切换
# DEEPSEEK_MODEL 选项（5/22 W3 Gate 前老板 + 后端定档，决策档案落 decisions/）:
#   deepseek-chat   —— V3 非 reasoning，content 直出，无 F31 风险；5/14 evals 11/15 通过（推荐 production 默认）
#   deepseek-v4-pro —— reasoning 模型，reasoning_tokens ≥ 36，maxTokens < 64 必空挂 + 偶发空挂；5/16 drill 实测 ping 2030ms（latent gap N2 / F31）
# ⚠️ production deploy 时不要直接复制 .env.local（dev 默认用 v4-pro），明示选 deepseek-chat 避 F31 长尾
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 单次战报 LLM 调用超时(ms,10000-300000,默认 50000)。50s 是 Vercel free tier 遗留约束;
# 腾讯云自托管建议 120000——6/12 揭幕战实测 50s 把 doubao 三风格并发掐死走 fallback。
REPORT_LLM_TIMEOUT_MS=

# Claude / OpenAI —— 仅本地 dev 用，prod NODE_ENV=production 时禁用
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# 默认 LLM provider：production 强制 doubao；dev 可以 doubao | deepseek | claude | openai
LLM_PROVIDER=doubao

# --- Supabase (境内可用替代：腾讯云 PostgreSQL + COS) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# --- 数据源（API-Football Pro $25/月） ---
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# --- 微信生态 ---
# WX_APPID + WX_SECRET 是 production 小程序登录必填，未配 production boot guard fail-fast。
WX_APPID=                      # 小程序 AppID
WX_SECRET=                     # 小程序 AppSecret
WX_MERCHANT_ID=                # （旧 v2 占位，未接）微信支付商户号
WX_MERCHANT_KEY=               # （旧 v2 占位，未接）商户密钥
WX_OFFICIAL_ACCOUNT_APPID=     # 公众号 AppID（W5+ 公众号接入触发）

# --- 微信支付 v3（L04 商户号；6/1 决策：服务号 H5 JSAPI + 安卓小程序双场景）---
# WXPAY_ENABLED=1 时 production boot guard 强校验下列配置；空=免费模式不阻塞上线。
WXPAY_ENABLED=                 # =1 开启微付费收款
WXPAY_MCHID=                   # 微信支付商户号
WXPAY_MERCHANT_SERIAL=         # 商户证书序列号
WXPAY_PRIVATE_KEY=             # 商户私钥（apiclient_key.pem 内容，PEM；\n 可转义）
WXPAY_API_V3_KEY=              # APIv3 密钥（32 字节，解密回调 AES-GCM）
WXPAY_PLATFORM_PUBLIC_KEY=     # 微信支付平台证书公钥（验回调签名，PEM）
WXPAY_SERVICE_APPID=           # 服务号 AppID（jsapi_mp / H5 场景）
WXPAY_SERVICE_SECRET=          # 服务号 AppSecret（H5 网页授权 snsapi_base 换 openid）
WXPAY_MINI_APPID=              # 小程序 AppID（jsapi_mini 场景，可=WX_APPID）
WXPAY_NOTIFY_URL=              # 回调地址 https://<备案域名>/api/payment/notify
AVATAR_PAYMENT_REQUIRED=       # =1 时球迷形象 ¥1 付费闸生效(须有已付未兑付 avatar_card 权益才生成);空=免费生成。与客户端 AVATAR_PAYMENT_LIVE + WXPAY_ENABLED 一起翻
NEXT_PUBLIC_AVATAR_PAYMENT_LIVE=  # 服务号 H5(/avatar)收费开关:=1 走付 ¥1 再生成;空=免费生成(默认)。与服务端 AVATAR_PAYMENT_REQUIRED 一起翻(改后须 rebuild)
REPORT_PAYWALL_ENABLED=        # 深度战报付费墙总开关:=1 时未付费用户锁 premium(赛事通 ¥19 / 决赛专栏 ¥9);空=全解锁、免费(默认)。收费链路已验证,可随时翻 1
MP_DRAFT_AUTO_PUSH=            # =1/true 时:战报+卡就绪后自动把三版(战术/好笑/追剧)推成服务号草稿 + 通知管理员(notifyOps);空=关(默认,需手动 mp-draft.sh)。须 WXPAY_SERVICE_* + 服务号 IP 白名单
MP_DRAFT_FAN_PORTRAIT=        # =1/true 时:推三版草稿(手动 all + 自动链路)均在草稿末尾附主/客队球迷形象(克制版半写真,AI 生成,文生图);空=关(默认)。须 FAN_PORTRAIT_PROVIDER=doubao + DOUBAO_API_KEY
MP_DRAFT_WEAPP_CTA=           # 草稿正文小程序 CTA(搜一搜读者→小程序转化桥):空/1=全开(两条文字链+可点小程序码,appid 取 WX_APPID 兜底 WXPAY_MINI_APPID);qr=只留码(data-miniprogram 链接需服务号已关联小程序,未关联 draft/add 报 45166→退此档);0=全关。注:mp-miniprogram 卡片标签 API 不收(45166,仅后台编辑器),卡片形态=码图包 <a data-miniprogram> 图片链接
XHS_AUTO_GEN=                # =1/true:战报就绪后自动生成本场「小红书」内容(图文笔记一图看懂/段子/追剧情绪 + 球迷写真),写比赛文件夹/<平台>/ + 企微推全文;空=关。手动:POST /api/admin/xhs-note
DOUYIN_AUTO_GEN=            # =1/true:同上,生成「抖音」短视频脚本(一图看懂卡点/段子解说 + 球迷写真过程·完播向);空=关。手动:POST /api/admin/douyin-note
CHANNELS_AUTO_GEN=          # =1/true:同上,生成「视频号」短视频脚本(微信站内·可导流小程序/公众号·情感共鸣向);空=关。手动:POST /api/admin/channels-note
SOCIAL_CONTENT_DIR=         # 社媒内容落盘根目录(每场一子文件夹、平台再分子目录 <比赛>/<平台>/);缺省 /data/social-content(生产建议挂 host 卷);写失败不阻断,内容仍走企微全文送达
FAN_PORTRAIT_PROVIDER=        # 球迷形象文生图 provider: mock(默认,占位图,测试用)/ doubao(豆包 Seedream,复用 DOUBAO_API_KEY/DOUBAO_IMAGE_* 配置)
SOCIAL_FAN_PORTRAIT=          # =1/true:社媒自动链路在企微附主/客队球迷形象样图(引流「自己也能生成」);空=关。须 FAN_PORTRAIT_PROVIDER=doubao
SOCIAL_COSTAR_SHOWCASE=       # =1/true:社媒链路附「与本场球星 AI 同框」引流样图(虚构球迷形象作自拍 → costar 合成,恒 AI 生成水印+「AI合成·非真实合影·非本人」披露);空=关。双门控:还须 FEATURE_FLAG_FAN_AVATAR_COSTAR 开。🔴 肖像权/深度合成红线·founder 拍板

# --- 内容审核（数美 / 网易易盾，二选一） ---
SHUMEI_ACCESS_KEY=
SHUMEI_TEXT_API=https://api-text-bj.fengkongcloud.com/text/v4
YIDUN_SECRET_ID=
YIDUN_SECRET_KEY=
YIDUN_BUSINESS_ID=             # 易盾业务 ID（普通文本，在易盾后台创建）

# --- 短链 / 小程序 Scheme ---
SHORT_LINK_DOMAIN=qiu.app       # 当前 code 硬编码 'qiu.app'，预留 env 给 W5+ 多域名支持
NEXT_PUBLIC_SITE_URL=https://qiu.app

# --- 监控 / 报警 ---
# 企微 / 钉钉机器人告警通道，production 至少配置一个（boot guard fail-fast）。
WECOM_BOT_WEBHOOK=
DINGTALK_BOT_WEBHOOK=

# --- Admin / 内部鉴权（production 必填）---
ADMIN_TOKEN=                   # admin route 鉴权（withAdmin 必需；不配则 admin 端点全 401）
INTERNAL_TOKEN=                # 内部 service 调用鉴权（card-prerender 链路）
IDEMPOTENCY_HMAC_KEY=          # TASK-07 H1 HMAC 签名 key（≥ 32 字节随机；不配幂等绕过）
OPENID_SIGN_KEY=              # R4：服务号 H5 openid token HMAC 签名 key（≥32 字节随机；不配回退 INTERNAL_TOKEN）

# 内测白名单（feature.internal_only=100 时生效）；逗号分隔 openid，≤ 20 人；6/4 dry-run 前由 PM fill。
# v0.1 用 env var（< 20 人足够）；PM 5/29 review 是否升 DB 表。
INTERNAL_ALLOWED_OPENIDS=

# --- 限流 / 幂等 (Upstash Redis REST；Edge middleware 共享态。腾讯云 Redis 走 TCP，Edge 不可用) ---
# RATELIMIT_STRICT=1（公测/决赛日开启）时，production 缺 Upstash 直接 fail-fast（boot guard，解架构 R2）。
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATELIMIT_STRICT=              # =1 强制 production 必须有共享限流存储（决赛日防刷穿+成本失控）

# --- 腾讯云 COS（卡片预生成 + CDN；迁腾讯云后启用，解架构 R1）---
# 配齐 ID/KEY/BUCKET/REGION 即从进程内存兜底切到 COS 对象存储（多实例共享）。
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=                    # 存储桶名（格式 name-appid，如 qhs-cards-1300000000）
COS_REGION=                    # 地域（如 ap-guangzhou）
COS_CDN_BASE_URL=              # CDN 回源域名（如 https://cdn.qiuhoushuo.cn）；空则用 COS 默认域名

# --- 运营调参（不配走默认）---
COST_CAP_CNY=100               # 单日成本封顶（CNY）；默认 100，决赛日可临时拉高
MAX_API_IN_FLIGHT=200          # 单进程并发请求上限；默认 200
CARD_PRERENDER_DISABLE=        # 设 'true' 关闭卡片预生成（决赛日运营开关）

# --- Cron 调度 ---
# 运维侧调度器（k8s CronJob / 阿里云 SCF 触发器 / Vercel Cron 等）调本项目 /api/cron/* 端点时携带的 token。
# Authorization: Bearer $ADMIN_API_SECRET。production 必须随机 32+ 字符。
ADMIN_API_SECRET=

# --- 运行环境 ---
NODE_ENV=development
