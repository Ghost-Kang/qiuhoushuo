{
  "name": "qiuhoushuo-web",
  "version": "0.1.0",
  "private": true,
  "description": "球后说 — Web 落地页 + API（战报生成 + 卡片渲染）",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:report": "tsx scripts/test-report.ts",
    "check:trademark": "tsx scripts/check-trademark.ts",
    "check:no-any": "tsx scripts/check-no-any-annotation.ts",
    "check:env-drift": "tsx scripts/check-env-drift.ts",
    "lint:spec": "tsx scripts/lint-task-spec.ts",
    "scan:alerts": "tsx scripts/scan-alert-calls.ts",
    "audit:dispatch": "tsx scripts/audit-task-dispatch.ts",
    "events:verify": "tsx scripts/verify-events-pipeline.ts",
    "dry-run:preflight": "tsx scripts/dry-run-preflight.ts",
    "ci": "pnpm check:trademark && pnpm check:no-any && pnpm check:env-drift && pnpm scan:alerts && pnpm evals:validate && pnpm build && pnpm lint && pnpm test:coverage && pnpm --filter @qhs/share-cards test",
    "evals:validate": "tsx evals/validate-fixtures.ts",
    "evals:run": "tsx evals/run-evals.ts",
    "evals:aggregate": "tsx scripts/aggregate-evals.ts",
    "grayscale": "tsx scripts/grayscale.ts",
    "drill:llm": "tsx scripts/llm-dual-provider-drill.ts",
    "kfactor": "tsx scripts/k-factor-report.ts",
    "gen:laoli-bgm": "tsx scripts/gen-laoli-bgm.ts",
    "gen:laoli-ref": "tsx scripts/gen-laoli-ref.ts",
    "smoke:laoli-video": "tsx scripts/smoke-laoli-video.ts"
