    "@remotion/renderer": "^4.0.481",
    "@resvg/resvg-js": "^2.6.2",
    "@supabase/supabase-js": "^2.45.4",
    "@upstash/redis": "^1.38.0",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "^4.0.481",
    "satori": "^0.10.13",
    "sharp": "0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
