/* 战报详情黄金页 · 视觉系统 v2 */
.loading { text-align: center; padding: 200rpx 0; color: var(--text-muted); }
/* 完赛但战报未生成的友好态(不白屏) */
.no-report { text-align: center; padding: 220rpx 48rpx; }
.no-report-ic { font-size: 80rpx; margin-bottom: 24rpx; }
.no-report-title { font-size: var(--fs-h2); font-weight: var(--fw-black); color: var(--text); }
.no-report-sub { margin-top: 16rpx; font-size: var(--fs-sm); color: var(--text-muted); }

/* Hero：径向 accent 光晕（零图片注入科技感；网格底纹按交叉审视砍掉，安卓 mask 不稳） */
.detail-hero { position: relative; padding: 40rpx 0 24rpx; overflow: hidden; }
.detail-hero::before {
  content: ''; position: absolute; top: -120rpx; left: -80rpx;
  width: 520rpx; height: 520rpx; pointer-events: none;
  background: radial-gradient(circle, var(--accent-glow) 0%, transparent 70%);
  filter: blur(40rpx); opacity: 0.9;
}
.title { position: relative; font-size: var(--fs-h1); font-weight: var(--fw-black); line-height: var(--lh-tight); }
.subtitle { position: relative; font-size: var(--fs-sm); color: var(--text-muted); margin-top: 16rpx; }

/* 一体化分段控件 + 滑动高亮块 */
.style-switcher {
  position: relative; display: flex;
  background: var(--surface); border: 1rpx solid var(--hairline);
  border-radius: var(--r-pill); padding: 6rpx; margin: 24rpx 0;
}
.style-tab {
  position: relative; z-index: 1; flex: 1; text-align: center;
  padding: 18rpx 0; font-size: var(--fs-sm); color: var(--text-muted);
  transition: color var(--dur-base) var(--ease-std);
}
.style-tab.active { color: var(--accent-ink); font-weight: var(--fw-semi); }
.style-switcher .thumb {
  position: absolute; top: 6rpx; left: 6rpx; z-index: 0;
  width: calc((100% - 12rpx) / 3); height: calc(100% - 12rpx);
  background: var(--accent); border-radius: var(--r-pill);
  box-shadow: var(--glow-accent);
  transition: transform var(--dur-slow) var(--ease-out);
}

/* 对阵头部:国旗 VS(国旗基础样式在 app.wxss 全局复用) */
.matchup { display: flex; align-items: center; justify-content: center; gap: var(--sp-3); margin: 8rpx 0 16rpx; }
.mu-side { display: flex; flex-direction: column; align-items: center; gap: var(--sp-1); min-width: 0; flex: 0 1 auto; max-width: 240rpx; }
.mu-team { font-size: var(--fs-sm); font-weight: var(--fw-semi); color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 100%; }
.mu-score { font-size: var(--fs-h1); font-weight: var(--fw-black); color: var(--accent); font-variant-numeric: tabular-nums; letter-spacing: 1rpx; }
.mu-colon { margin: 0 8rpx; color: var(--text-muted); font-weight: var(--fw-bold); }

.meta { font-size: var(--fs-xs); color: var(--text-muted); margin-bottom: 8rpx; font-variant-numeric: tabular-nums; }
.dot { margin: 0 12rpx; }

/* 一图看懂 PNG 本身即一张完整卡片(深色底/圆角/徽标都在图内),不再外套框:
   去掉背景渐变/边框/阴影/内边距/装饰光斑,避免"框中框"观感(用户反馈套大框看着不舒服)。
   容器仅保留外边距 + 作为点击保存的命中区。 */
.brief-card {
  position: relative;
  margin: 28rpx 0 36rpx;
}
/* 一图看懂加载占位:预留 3:4 卡片高度(与 .brief-image PNG 同比),图到了原位替换不跳版。复用全局 .skeleton 微光。 */
.brief-skeleton {
  width: 100%;
  padding-top: 133.3%;
  margin: 28rpx 0 36rpx;
  border-radius: var(--r-md);
}
/* 一图看懂:直接展示服务端新版 PNG(3:4),宽度自适应。
   旧版 WXML 重搭的 brief-title/tags/grid/reason/lens/data/share 已废弃(改显示 PNG,杜绝双渲染分叉)。 */
.brief-image {
  position: relative;
  display: block;
  width: 100%;
  border-radius: var(--r-md);
}
.brief-wx-save {
  display: block; text-align: center; margin: 16rpx 0 8rpx;
  font-size: var(--fs-sm); font-weight: var(--fw-semi); color: var(--accent-ink);
  padding: 18rpx 0; border: 1rpx solid var(--accent-ink); border-radius: 16rpx;
}
.brief-download {
  position: relative;
  display: inline-flex;
  margin-top: 18rpx;
  padding: 12rpx 18rpx;
  border-radius: var(--r-pill);
  background: rgba(255,255,255,0.10);
  color: var(--text);
  font-size: var(--fs-2xs);
  font-weight: var(--fw-semi);
}

.tactics-card {
  position: relative;
  margin: 24rpx 0;
  padding: 24rpx;
  border-radius: var(--r-lg);
  background: var(--surface);
  border: 1rpx solid var(--hairline);
}
.tactics-image {
  width: 100%;
  border-radius: var(--r-md);
  background: rgba(255,255,255,0.04);
}
.tactics-download {
  position: relative;
  display: inline-flex;
  margin-top: 18rpx;
  padding: 12rpx 18rpx;
  border-radius: var(--r-pill);
  background: rgba(255,255,255,0.10);
  color: var(--text);
  font-size: var(--fs-2xs);
  font-weight: var(--fw-semi);
}

.lead {
  font-size: var(--fs-h3); line-height: 1.7; font-style: italic;
  margin: 24rpx 0; padding-left: 16rpx; border-left: 4rpx solid var(--accent);
}
.body-p { font-size: var(--fs-body); line-height: var(--lh-body); margin-bottom: 24rpx; }

.section-title {
  margin: 40rpx 0 20rpx;
  font-size: var(--fs-sm);
  color: var(--text-muted);
  font-weight: var(--fw-semi);
  letter-spacing: 4rpx;
}
.moments { margin: 32rpx 0 40rpx; }
.moment-card {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: var(--r-lg);
  background: var(--bg-elev-1);
  border: 1rpx solid var(--hairline-2);
  box-shadow: var(--elev-1);
}
.moment-visual {
  position: relative;
  flex: 0 0 184rpx;
  height: 132rpx;
  overflow: hidden;
  border-radius: var(--r-md);
  background: linear-gradient(135deg, var(--accent), var(--surface-2));
  border: 1rpx solid var(--hairline-2);
}
.moment-image {
  display: block;
  flex: 0 0 184rpx;
  width: 184rpx;
  height: 132rpx;
  border-radius: var(--r-md);
  background: var(--surface-2);
  border: 1rpx solid var(--hairline-2);
}
.moment-visual.pressure { background: linear-gradient(135deg, #17d6a3, var(--surface-2)); }
.moment-visual.turning_point { background: linear-gradient(135deg, #9b8cff, var(--surface-2)); }
.pitch-line { position: absolute; background: rgba(255,255,255,0.42); }
.pitch-line.horizontal { left: 16rpx; right: 16rpx; top: 50%; height: 2rpx; }
.pitch-line.vertical { top: 16rpx; bottom: 16rpx; left: 50%; width: 2rpx; }
.ball {
  position: absolute;
  right: 20rpx;
  bottom: 18rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  background: var(--text);
  box-shadow: 0 0 18rpx rgba(255,255,255,0.45);
}
.moment-copy { flex: 1; min-width: 0; }
.moment-minute { font-size: var(--fs-2xs); color: var(--accent); font-weight: var(--fw-semi); margin-bottom: 8rpx; }
.moment-title { font-size: var(--fs-sm); color: var(--text); font-weight: var(--fw-black); line-height: var(--lh-snug); }
.moment-desc { margin-top: 8rpx; font-size: var(--fs-xs); color: var(--text-muted); line-height: var(--lh-snug); }

/* 数据可视化条：主队 accent 渐变填充 + 内发光（color-mix 兼容差→两色渐变兜底） */
.stat-block { margin: 40rpx 0; }
.stat-row { margin-bottom: 24rpx; }
.stat-label { display: flex; justify-content: space-between; font-size: var(--fs-xs); color: var(--text-muted); margin-bottom: 12rpx; }
.stat-label .v { color: var(--text); font-variant-numeric: tabular-nums; font-weight: var(--fw-semi); }
.stat-track { position: relative; height: 14rpx; border-radius: 100rpx; background: var(--surface-2); overflow: hidden; }
.stat-fill {
  position: absolute; left: 0; top: 0; bottom: 0; border-radius: 100rpx;
  background: linear-gradient(90deg, var(--accent), rgba(255,255,255,0.55));
  box-shadow: 0 0 12rpx var(--accent-glow);
  transition: width var(--dur-slow) var(--ease-out);
}

/* 出图入口卡：把金句做成"成品卡"，accent 光晕 + 引导分享 + 合规水印 */
.inline-card {
  position: relative; margin: 48rpx 0; overflow: hidden;
  border-radius: var(--r-lg); background: var(--bg-elev-1);
  border: 1rpx solid var(--hairline-2); box-shadow: var(--elev-2);
  padding: 56rpx 48rpx 48rpx;
}
.inline-card::before {
  content: ''; position: absolute; right: -100rpx; top: -100rpx;
  width: 360rpx; height: 360rpx; pointer-events: none;
  background: radial-gradient(circle, var(--accent-glow), transparent 70%); filter: blur(30rpx);
}
.inline-card .ic-quote { position: relative; font-size: var(--fs-h2); font-weight: var(--fw-black); line-height: var(--lh-snug); }
.inline-card .ic-cta { position: relative; display: inline-block; margin-top: 32rpx; color: var(--accent); font-size: var(--fs-sm); font-weight: var(--fw-semi); }
.inline-card .ic-mark { position: absolute; right: 32rpx; bottom: 24rpx; font-size: var(--fs-2xs); color: var(--text-faint); letter-spacing: 2rpx; }

/* 付费墙：上方内容渐隐 → 锁条 */
.paywall-fade { height: 160rpx; margin-bottom: -120rpx; position: relative; z-index: 2; pointer-events: none; background: linear-gradient(180deg, transparent, var(--bg) 90%); }
.paywall {
  position: relative; margin: 16rpx 0 48rpx; padding: 48rpx 40rpx; text-align: center;
  background: var(--surface); border: 1rpx solid var(--hairline-2);
  border-radius: var(--r-lg); box-shadow: var(--elev-2);
}
.paywall .lock { font-size: 40rpx; margin-bottom: 16rpx; }
.paywall-title { font-size: var(--fs-sm); color: var(--text-muted); margin-bottom: 28rpx; line-height: var(--lh-snug); }
/* iOS 服务号引导文案(策略 C):站内不售卖,仅引导关注服务号 */
.paywall-ios-hint { font-size: var(--fs-2xs); color: var(--text-muted); line-height: var(--lh-snug); margin-bottom: 28rpx; }
.paywall-btn {
  background: var(--accent); color: var(--accent-ink);
  border-radius: var(--r-pill); padding: 24rpx 64rpx; font-weight: var(--fw-semi);
  box-shadow: var(--glow-accent); display: inline-block;
}
.paywall-btn::after { border: none; }

.tags { margin: 32rpx 0 200rpx; }

/* 固定底部 actions：保留 0.92 安卓兜底（不降到 0.72）+ 底部安全区 */
.actions {
  position: fixed; bottom: 0; left: 0; right: 0;
  display: flex; gap: 16rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(10,10,10,0.92);
  backdrop-filter: blur(20rpx);
}
.action-btn {
  flex: 1; text-align: center; padding: 24rpx 0;
  border-radius: var(--r-pill); font-size: var(--fs-sm);
  border: 1rpx solid var(--hairline-2); color: var(--text);
}
.action-btn.primary {
  flex: 2; background: var(--accent); color: var(--accent-ink);
  font-weight: var(--fw-semi); border: none; box-shadow: var(--glow-accent);
}

/* 分享底部弹层 */
.sheet-mask { position: fixed; inset: 0; background: rgba(0,0,0,0.6); z-index: 100; display: flex; align-items: flex-end; }
.sheet { width: 100%; background: var(--bg-elev-1); border-radius: var(--r-lg) var(--r-lg) 0 0; padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom)); }
.sheet-title { text-align: center; color: var(--text-muted); font-size: var(--fs-sm); margin-bottom: 32rpx; }
.sheet-grid { display: flex; flex-wrap: wrap; gap: 0; }
/* box-sizing/min-width:0 + overflow 收紧:防 button(微信好友 open-type=share)触区外溢误触相邻「存图」项 */
.sheet-item { width: 25%; box-sizing: border-box; min-width: 0; text-align: center; padding: 16rpx 0; font-size: var(--fs-2xs); color: var(--text); background: transparent; border: none; line-height: 1.4; overflow: hidden; }
.sheet-item::after { display: none; border: none; }
button.sheet-item { margin: 0; }
.sheet-icon { width: 88rpx; height: 88rpx; margin: 0 auto 12rpx; border-radius: 50%; background: var(--surface-2); display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 600; }
/* 各平台柔和品牌色:同属微信用绿,小红书红、微博橙,glyph 也区分,整体清晰不雷同 */
.sheet-icon-wechat,
.sheet-icon-moments { background: rgba(7,193,96,0.16); color: #07c160; }
.sheet-icon-xhs { background: rgba(255,36,66,0.16); color: #ff2442; }
.sheet-icon-weibo { background: rgba(255,130,0,0.16); color: #ff8200; }
.sheet-cancel { margin-top: 24rpx; text-align: center; padding: 24rpx; border-top: 1rpx solid var(--hairline); color: var(--text-muted); }
