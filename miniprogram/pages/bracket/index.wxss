.page { display: flex; flex-direction: column; height: 100vh; background: #07224D; }
.hint { padding: 16rpx 24rpx; font-size: 22rpx; color: #A9C0E8; text-align: center; }
.scroll { flex: 1; overflow: hidden; }
.bracket-img { width: 100%; display: block; }
.loading { padding: 80rpx 0; text-align: center; color: #A9C0E8; font-size: 26rpx; }
.tip { padding: 24rpx; text-align: center; color: #5E6C7C; font-size: 22rpx; }
.footer-pad { height: 160rpx; }
.save-bar { position: fixed; left: 0; right: 0; bottom: 0; padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom)); background: rgba(7,34,77,0.96); border-top: 1rpx solid rgba(255,255,255,0.08); }
.save-btn { width: 100%; height: 88rpx; line-height: 88rpx; border-radius: 999rpx; background: #FFD24A; color: #5A3B00; font-size: 30rpx; font-weight: 700; border: none; }
.save-btn-hover { opacity: 0.85; }
