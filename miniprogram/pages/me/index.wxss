/* 我的页 · 视觉系统 v2 */
.profile { padding: var(--sp-5) 0; }
.nick { font-size: var(--fs-h2); font-weight: var(--fw-bold); }
.hint { font-size: var(--fs-xs); color: var(--text-muted); margin-top: 8rpx; }

/* 未成年人提示：用 warning 语义色（已与情绪 accent 解耦） */
.minor-notice {
  margin-bottom: 24rpx; padding: 24rpx;
  border: 1rpx solid rgba(245,166,35,0.28); background: rgba(245,166,35,0.08);
  color: var(--warning); border-radius: var(--r-sm); font-size: var(--fs-xs); line-height: 1.5;
}

/* 菜单卡：分组列表 */
.menu {
  background: var(--surface); border: 1rpx solid var(--hairline);
  border-radius: var(--r-md); overflow: hidden; margin-top: 16rpx;
}
.row {
  position: relative; display: flex; align-items: center; justify-content: space-between;
  min-height: 96rpx; padding: 0 var(--sp-4);
  border-bottom: 1rpx solid var(--hairline); font-size: var(--fs-body);
}
.row:last-child { border-bottom: none; }
.row-val { color: var(--text-muted); font-variant-numeric: tabular-nums; }
/* 仅可点击行带 chevron + 按压反馈 */
.row.tappable::after { content: '›'; color: var(--text-faint); font-size: 40rpx; line-height: 1; }
.row.tappable:active { background: var(--surface-2); }

/* 付费记录明细卡 */
/* 收藏金句列表(点「收藏金句」展开) */
.quotes-list {
  margin-top: 16rpx; padding: var(--sp-3) var(--sp-4);
  background: var(--surface); border: 1rpx solid var(--hairline); border-radius: var(--r-md);
}
.quotes-empty { font-size: var(--fs-sm); color: var(--text-faint); line-height: 1.6; padding: 8rpx 0; }
.quote-item { padding: 20rpx 0; border-bottom: 1rpx solid var(--hairline); }
.quote-item:last-child { border-bottom: none; }
.quote-item:active { opacity: 0.7; }
.quote-text { font-size: var(--fs-body); color: var(--text); line-height: 1.5; }
.quote-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 10rpx; }
.quote-src { font-size: var(--fs-2xs); color: var(--text-faint); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.quote-del { font-size: var(--fs-xs); color: var(--text-muted); padding: 6rpx 18rpx; border: 1rpx solid var(--hairline-2); border-radius: var(--r-pill); margin-left: 16rpx; }
.quote-del:active { background: var(--surface-2); }

.bills {
  margin-top: 24rpx; padding: var(--sp-4);
  background: var(--surface); border: 1rpx solid var(--hairline); border-radius: var(--r-md);
}
.bills-title { font-size: var(--fs-xs); color: var(--text-muted); margin-bottom: 16rpx; }
.bill { padding: 16rpx 0; border-bottom: 1rpx solid var(--hairline); }
.bill:last-child { border-bottom: none; padding-bottom: 0; }
.bill-line { display: flex; align-items: center; justify-content: space-between; }
.bill-sku { font-size: var(--fs-body); }
.bill-amount { font-size: var(--fs-body); font-weight: var(--fw-bold); font-variant-numeric: tabular-nums; }
.bill-date { font-size: var(--fs-2xs); color: var(--text-faint); margin-top: 6rpx; }

.legal {
  margin-top: 64rpx; padding: var(--sp-4);
  background: var(--surface); border: 1rpx solid var(--hairline);
  border-radius: var(--r-md); font-size: var(--fs-2xs); color: var(--text-muted); line-height: 1.8;
}
.legal-links { display: flex; flex-wrap: wrap; }
.legal-link { color: #00e5ff; }
.legal-link:active { opacity: 0.6; }
